{
    "name": "101-app",
    "version": "1.0.0",
    "main": "index.js",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "prettify": "prettier -l --write \"**/*.js\"",
        "test": "jest",
        "build": "babel src --out-dir dist --extensions \".ts,.tsx\"",
        "dev": "nodemon --watch 'src/**/*.ts' --exec \"npm run build && node dist/index.js\"",
        "start": "node dist/index.js"
    },
    "dependencies": {
        "dotenv": "^17.3.1",
        "express": "^4.18.2",
        "mysql2": "^2.3.3",
        "sqlite3": "^5.1.2",
        "typescript": "^5.9.3",
        "uuid": "^9.0.0",
        "wait-port": "^1.0.4"
    },
    "resolutions": {
        "ansi-regex": "5.0.1"
    },
    "prettier": {
        "trailingComma": "all",
        "tabWidth": 4,
        "useTabs": false,
        "semi": true,
        "singleQuote": true
    },
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-typescript": "^7.28.5",
        "@types/express": "^5.0.6",
        "@types/node": "^25.3.3",
        "@types/uuid": "^11.0.0",
        "babel-plugin-add-import-extension": "^1.6.0",
        "jest": "^29.3.1",
        "nodemon": "^2.0.20",
        "prettier": "^2.7.1"
    }
}
