{
    "name": "backend",
    "version": "1.0.0",
    "main": "index.js",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "prettify": "prettier -l --write \"**/*.js\"",
        "test": "jest",
        "build": "babel src --out-dir dist --extensions \".ts,.tsx\"",
        "dev": "nodemon --watch 'src/**/*.ts' --exec \"npm run build && node dist/index.js\"",
        "start": "node dist/index.js"
    },
    "dependencies": {
        "@todo-app/shared": "1.0.0",
        "connect-sqlite3": "^0.9.13",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^4.18.2",
        "express-session": "^1.17.3",
        "mysql2": "^2.3.3",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "sqlite": "^5.1.1",
        "sqlite3": "^5.1.2",
        "typescript": "^5.9.3",
        "uuid": "^9.0.1",
        "wait-port": "^1.0.4"
    },
    "resolutions": {
        "ansi-regex": "5.0.1"
    },
    "prettier": {
        "trailingComma": "all",
        "tabWidth": 4,
        "useTabs": false,
        "semi": true,
        "singleQuote": true
    },
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-typescript": "^7.28.5",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.17.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.3",
        "@types/passport": "^1.0.16",
        "@types/passport-google-oauth20": "^2.0.14",
        "@types/uuid": "^11.0.0",
        "babel-jest": "^30.2.0",
        "babel-plugin-add-import-extension": "^1.6.0",
        "jest": "^30.2.0",
        "nodemon": "^2.0.20",
        "prettier": "^2.7.1"
    }
}
